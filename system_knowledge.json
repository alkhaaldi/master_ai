      "cover.open_cover/close_cover": "Control covers (inverted!)",
      "input_boolean.turn_on/off": "Toggle input_boolean helpers"
    },
    "repair_patterns": {
      "backlight_off": {
        "detect": "ha_get_state entity_id=light.*backlight* — check for state=off",
        "fix": "ha_call_service domain=light service=turn_on entity_id={each_off_backlight}",
        "prevent": "verify automation.hfz_l_d_lzrr_backlight_always_on is on"
      },
      "ac_too_cold": {
        "detect": "ha_get_state entity_id=climate.* — check temperature < 18",
        "fix": "ha_call_service domain=climate service=set_temperature entity_id={ac} temperature=21"
      },
      "automation_disabled": {
        "detect": "ha_get_state entity_id=automation.* — check state=off",
        "fix": "ha_call_service domain=automation service=turn_on entity_id={auto_id}"
      },
      "camera_offline": {
        "detect": "ha_get_state entity_id=camera.* — check state=unavailable",
        "fix": "ssh_run cmd='ping -c 3 {camera_ip}' then suggest power cycle or NVR restart"
      },
      "device_unavailable": {
        "detect": "http_request url=http://localhost:9000/entity-map/health",
        "fix": "check WiFi signal, power cycle device, or remove stale entity"
      }
    },
    "safety_rules": [
      "Never modify automations without user confirmation for medium/high risk",
      "Never set AC below 18 or above 30",
      "Always check current state before making changes",
      "Log all repairs to memory_store for learning",
      "If unsure, suggest fix to user instead of auto-applying"
    ]
  },
