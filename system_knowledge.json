  "self_repair": {
    "ha_call_service_capabilities": {
      "automation.turn_on": "Enable a disabled automation",
      "automation.turn_off": "Disable an automation",
      "automation.trigger": "Manually trigger an automation",
      "scene.turn_on": "Activate a scene",
